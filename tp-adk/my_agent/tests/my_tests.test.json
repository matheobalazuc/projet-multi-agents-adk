{
  "test_suite": "Travel Assistant - ADK Tests",
  "tests": [
    {
      "id": "test_001",
      "description": "Planification complète d'un voyage à Tokyo",
      "input": "Je veux aller à Tokyo depuis Paris du 15 au 22 juillet pour 2 personnes.",
      "expected_keywords": ["vol", "hôtel", "activité", "budget", "Tokyo"],
      "agent": "travel_assistant"
    },
    {
      "id": "test_002",
      "description": "Recherche de vols uniquement",
      "input": "Trouve-moi des vols Paris → Rome pour le 10 août.",
      "expected_keywords": ["vol", "prix", "compagnie"],
      "agent": "flight_agent"
    },
    {
      "id": "test_003",
      "description": "Calcul de budget",
      "input": "Calcule le budget pour 5 nuits d'hôtel à 120€/nuit, vol à 350€ et 100€ d'activités.",
      "expected_keywords": ["budget", "total", "EUR"],
      "agent": "budget_agent"
    },
    {
      "id": "test_004",
      "description": "Météo destination",
      "input": "Quelle météo à Barcelone en septembre ?",
      "expected_keywords": ["météo", "température", "Barcelone"],
      "agent": "weather_agent"
    }
  ]
}